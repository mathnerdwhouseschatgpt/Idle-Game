{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Idle Civilization",
  "version": "0.5.0",
  "identifier": "com.idlecivilization.game",
  "build": {
    "beforeDevCommand": "npm run build",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../web",
    "devUrl": "http://localhost:8000/web/"
  },
  "app": {
    "windows": [
      {
        "title": "Idle Civilization",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 640,
        "backgroundColor": "#11130f"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
