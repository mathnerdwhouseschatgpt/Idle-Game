{
  "name": "idle-civilization",
  "version": "0.5.0",
  "type": "module",
  "description": "Idle Civilization - grow from foragers to a Type III empire.",
  "scripts": {
    "prepare": "node tools/run_python.cjs tools/generate_buildings.py",
    "compile": "tsc -p tsconfig.json",
    "build": "npm run prepare && npm run compile",
    "start": "npm run build && node tools/serve_static.cjs",
    "web:build": "node tools/run_python.cjs tools/package_web.py",
    "pages:build": "node tools/run_python.cjs tools/package_web.py --pages",
    "tauri:dev": "npm run build && tauri dev",
    "tauri:build": "npm run build && tauri build"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.4.0",
    "typescript": "^5.8.3"
  }
}
