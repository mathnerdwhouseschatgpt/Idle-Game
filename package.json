{
  "name": "idle-civilization",
  "version": "0.5.0",
  "description": "Idle Civilization — grow from foragers to a Type III empire.",
  "main": "electron/main.js",
  "scripts": {
    "prepare": "python tools/generate_buildings.py",
    "start": "npm run prepare && electron .",
    "dist": "npm run prepare && electron-builder",
    "web:build": "python tools/package_web.py"
  },
  "build": {
    "appId": "com.idlecivilization.game",
    "productName": "Idle Civilization",
    "files": [
      "electron/**/*",
      "web/**/*",
      "design/data/*.json"
    ],
    "directories": {
      "buildResources": "build",
      "output": "dist"
    },
    "asar": true,
    "extraResources": [
      {
        "from": "web/data",
        "to": "resources/data"
      }
    ],
    "mac": {
      "category": "public.app-category.games"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "devDependencies": {
    "electron": "^27.0.0",
    "electron-builder": "^24.6.4"
  }
}

